[user]
	name = fukayatsu
	email = fukayatsu@gmail.com
[color]
	ui = auto
[core]
	editor = subl -w
	pager = less -x4 -r
	excludesfile = ~/.gitignore
	autocrlf = input
[merge]
        tool = p4merge
[mergetool]
        keepBackup = false
[mergetool "p4merge"]
        path = p4merge
        keepTemporaries = false
        trustExitCode = false
[alias]
  aa = add . -v
  au = add . -uv
  co = checkout
  cob = checkout -b
  cot = checkout -t
  com = checkout master
  cogl = checkout HEAD -- Gemfile.lock
  b = branch
  ba = branch -a
  bd = branch -d
  ft = fetch
  ci = commit -v
  cia = commit -av
  cih = commit --amend -C HEAD
  cim = commit -m
  ps = push
  ciam = commit -am
  rb = rebase
  rbm = rebase master
  rbh = rebase HEAD
  d = diff
  cl = clone
  st = status -sb
  vlog = log --pretty=format:'%C(red)%h%Creset %C(cyan)an>\
       %Creset -%C(yellow)%d%Creset %s %Cgreen(%cr)%Creset'\
       --abbrev-commit --date=relative

[push]
	default = simple
[heroku]
	account = fukayatsu
